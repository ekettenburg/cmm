class DateDemo;
// PHP-style date formatting. Date.date = local time, Date.gmdate = UTC.
fn main() {
    e = 1700000000;
    Console.println(Date.gmdate("Y-m-d H:i:s", e));
    Console.println(Date.gmdate("l, F j, Y", e));
    Console.println(Date.gmdate("D jS M 'y g:i A", e));
    Console.println(Date.gmdate("c", e));
    Console.println(Date.gmdate("r", e));
    now = Date.now();
    Console.print("current UTC: ");
    Console.println(Date.gmdate("Y-m-d H:i:s", now));
}
