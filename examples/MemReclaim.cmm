class MemReclaim;

fn build(n: Int) -> Int {
    s = "";
    i = 0;
    while (i < n) {
        s = (s + "x");
        i++;
    }
    len = s.length();
    return len;
}

fn main() {
    total = 0;
    r = 0;
    while (r < 3000) {
        c = build(3000);
        total = (total + c);
        r++;
    }
    Console.print("total = ");
    Console.println(total);
}
