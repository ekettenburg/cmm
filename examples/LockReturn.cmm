class LockReturn;

@counter: Int;

fn bump() -> Int {
    use @counter {
        @counter++;
        cur = @counter;
        return cur;
    }
}

fn many() {
    i = 0;
    while (i < 1000) {
        x = bump();
        i++;
    }
}

fn main() {
    j1 = run many();
    j2 = run many();
    j3 = run many();
    a = wait j1;
    b = wait j2;
    c = wait j3;
    Console.print("counter = ");
    Console.println(@counter);
}
